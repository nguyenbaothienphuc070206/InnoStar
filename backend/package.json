{
  "name": "greenpark-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "migration:generate": "typeorm migration:generate ./src/database/migrations/AutoMigration -d ./dist/database/data-source.js",
    "migration:run": "typeorm migration:run -d ./dist/database/data-source.js",
    "migration:revert": "typeorm migration:revert -d ./dist/database/data-source.js"
  },
  "dependencies": {
    "@nestjs/config": "3.3.0",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/typeorm": "10.0.2",
    "@nestjs/common": "10.4.4",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/platform-socket.io": "10.4.4",
    "@nestjs/throttler": "6.2.1",
    "@nestjs/websockets": "10.4.4",
    "axios": "1.7.7",
    "bcryptjs": "2.4.3",
    "bullmq": "5.16.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.4.1",
    "joi": "17.13.3",
    "helmet": "8.0.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.13.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "socket.io": "4.8.1",
    "typeorm": "0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.3",
    "@nestjs/testing": "10.4.4",
    "@types/express": "5.0.0",
    "@types/bcryptjs": "2.4.6",
    "@types/multer": "1.4.12",
    "@types/node": "20.16.5",
    "@types/passport-jwt": "4.0.1",
    "ts-node": "10.9.2",
    "typescript": "5.6.2"
  }
}
